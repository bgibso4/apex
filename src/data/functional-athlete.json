      "full_ankle": {
        "name": "Full Ankle Protocol",
        "duration_min": 10,
        "steps": [
          { "name": "Plantar Fascia Roll", "prescription": "30 sec/foot", "notes": "Lacrosse ball or golf ball on hard surface", "progression": "Increase pressure over weeks" },
          { "name": "Calf SMR", "prescription": "30 sec/side", "notes": "Foam roller or lacrosse ball", "progression": "Add ankle circles while rolling" },
          { "name": "Banded Ankle Mobilization", "prescription": "2×10 reps/side", "notes": "Band anchored low, drive knee forward over toes", "progression": "Add weight Wk 5+ (hold KB)" },
          { "name": "Short Foot Exercise (Doming)", "prescription": "3×8 sec holds", "notes": "Wk 1-4: seated → Wk 5-8: standing → Wk 9-12: single-leg", "progression": "Most important foot exercise" },
          { "name": "Toe Yoga", "prescription": "2×8 reps", "notes": "Big toe up/small toes down, then switch", "progression": "Add tempo holds Wk 5+" },
          { "name": "Single-Leg Balance", "prescription": "2×20 sec/side", "notes": "Wk 1-4: eyes open → Wk 5-8: eyes closed → Wk 9-12: unstable", "progression": "Progress surface difficulty" },
          { "name": "Wall Ankle Mobilization (K2W)", "prescription": "2×10 reps/side", "notes": "Knee tracks over 2nd-3rd toe, measure distance", "progression": "Track cm improvement" },
          { "name": "Barefoot Cossack Squat", "prescription": "1×5/side", "notes": "Bodyweight only, full depth", "progression": "Add load Wk 9+" }
        ]
      },
      "abbreviated_ankle": {
