          { "name": "Wall Ankle Mobilization (3-way)", "prescription": "8 reps each direction/side", "notes": "Straight, inside, outside" },
          { "name": "Single-Leg Balance (Eyes Closed)", "prescription": "2×15 sec/side", "notes": "Challenge proprioception" }
        ]
      },
